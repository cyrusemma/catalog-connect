# Client (Vite) — exposed to the browser
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_WHATSAPP_NUMBER=233244000000

# Public-facing site URL used by the OG serverless function to build canonical
# product links. Set this to your production Vercel URL.
VITE_SITE_URL=https://your-store.vercel.app
VITE_STORE_NAME=Catalog by Cyrus

# Server only — used by /api/og/[id] to read products bypassing RLS.
# NEVER prefix with VITE_ (would leak it to the client bundle).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
