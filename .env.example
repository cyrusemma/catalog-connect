# Environment Variables Template
# Copy this to .env and fill in your Supabase credentials
# ⚠️  IMPORTANT: Never commit .env to git!

# Supabase Public Keys (SAFE to use VITE_ prefix for client-side)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Supabase Project ID
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Server-side environment variables
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# 🔐 CRITICAL: Service role key - NEVER expose this!
# This key bypasses RLS - only use in server functions
# Keep this secret and never commit to git
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
